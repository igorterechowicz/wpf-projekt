<UserControl x:Class="wpf_projekt.Views.SummaryView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <!-- HEADER -->
            <TextBlock Text="Podsumowanie"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- FILTRY -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Konto"/>
                    <ComboBox x:Name="AccountComboBox"
                              Width="160"
                              SelectionChanged="FilterChanged"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Rok"/>
                    <ComboBox x:Name="YearComboBox"
                              Width="100"
                              SelectionChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Miesiąc"/>
                    <ComboBox x:Name="MonthComboBox"
                              Width="120"
                              SelectionChanged="FilterChanged"/>
                </StackPanel>

            </StackPanel>

            <!-- KARTY -->
            <UniformGrid Columns="3">

                <Border Background="#DCFCE7" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Przychody" FontWeight="Bold"/>
                        <TextBlock Name="IncomeText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="Green"/>
                    </StackPanel>
                </Border>

                <Border Background="#FEE2E2" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Wydatki" FontWeight="Bold"/>
                        <TextBlock Name="ExpenseText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="Red"/>
                    </StackPanel>
                </Border>

                <Border Background="#E0E7FF" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Bilans" FontWeight="Bold"/>
                        <TextBlock Name="BalanceText"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>

    </Grid>
</UserControl>