<UserControl x:Class="wpf_projekt.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">

        <!-- FILTRY -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">

            <!-- DATA / SORTOWANIE -->
            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Data" FontWeight="Bold"/>
                <ComboBox Name="DateSortComboBox"
                          Width="150"
                          SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="Od najnowszej"/>
                    <ComboBoxItem Content="Od najstarszej"/>
                </ComboBox>
            </StackPanel>

            <!-- KATEGORIA -->
            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Kategoria" FontWeight="Bold"/>
                <ComboBox Name="CategoryFilterComboBox"
                          Width="150"
                          SelectionChanged="FilterChanged"/>
            </StackPanel>

            <!-- RODZAJ / TYP -->
            <StackPanel>
                <TextBlock Text="Rodzaj" FontWeight="Bold"/>
                <ComboBox Name="TypeFilterComboBox"
                          Width="150"
                          SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="Wszystkie"/>
                    <ComboBoxItem Content="Wydatek"/>
                    <ComboBoxItem Content="Przychód"/>
                </ComboBox>
            </StackPanel>

        </StackPanel>

        <!-- TABELA -->
        <DataGrid Name="TransactionsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="400">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding Date}" />
                <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" />
                <DataGridTextColumn Header="Kwota" Binding="{Binding Amount}" />
                <DataGridTextColumn Header="Typ" Binding="{Binding TypeName}" />
                <DataGridTextColumn Header="Opis" Binding="{Binding Description}" />
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>

</UserControl>