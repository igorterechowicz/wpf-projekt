<Window x:Class="wpf_projekt.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj nową kategorię" Height="180" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Nazwa nowej kategorii:" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>

        <TextBox x:Name="CategoryNameTextBox" Grid.Row="1" Height="25" VerticalAlignment="Top" Padding="2"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Anuluj" Width="70" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="Zapisz" Width="70" Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>