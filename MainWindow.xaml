<Window x:Class="wpf_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:wpf_projekt.Views"
        Title="Zarządzanie Finansami" Height="600" Width="450"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Style, żeby nie powtarzać kodu dla każdego pola -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Control" x:Key="InputStyle">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl>
        <!-- 🔵 ZAKŁADKA 1 -->
        <TabItem Header="Dodaj">

            <!-- Biała karta z cieniem na środku ekranu -->
        <Border Background="White" Margin="30" Padding="25" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Nowa Transakcja" FontSize="24" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- 1. Typ transakcji na samej górze (Zmienia kategorie!) -->
                <TextBlock Text="Typ transakcji:" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="ExpenseRadio" Content="Wydatek" IsChecked="True" Margin="0,0,20,0" FontSize="14" Checked="TransactionType_Changed"/>
                    <RadioButton x:Name="IncomeRadio" Content="Przychód" FontSize="14" Checked="TransactionType_Changed"/>
                </StackPanel>

                <!-- 2. Kategoria (Zależna od typu u góry) -->
                <TextBlock Text="Kategoria:" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CategoryComboBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

                <!-- 3. Kwota -->
                <TextBlock Text="Kwota (zł):" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="AmountTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10" />

                <!-- 4. Data -->
                <TextBlock Text="Data transakcji:" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="TransactionDatePicker" Style="{StaticResource InputStyle}" Margin="0,0,0,10" />

                <!-- 5. Opis -->
                <TextBlock Text="Opis (opcjonalnie):" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="DescriptionTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,25" />

                <!-- Przycisk Zapisz -->
                <Button x:Name="SaveButton" Content="Dodaj transakcję" Click="SaveButton_Click" 
                        Padding="12" Background="#2563EB" Foreground="White" FontSize="16" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
        </TabItem>
        <!-- 🟢 ZAKŁADKA 2 -->
        <TabItem Header="Transakcje">
            <views:TransactionsView/>
        </TabItem>

        <!-- 🟣 ZAKŁADKA 3 -->
        <TabItem Header="Podsumowanie">
            <views:SummaryView/>
        </TabItem>

        </TabControl>
    </Grid>
</Window>