<Window x:Class="wpf_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:wpf_projekt.Views"
        Title="Zarządzanie Finansami" Height="600" Width="700"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <TabControl>

            <!-- 🔵 DODAJ -->
            <TabItem Header="Dodaj">
                <Border Background="White" Margin="10" Padding="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="Dodaj nową transakcję"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Kwota (zł):"/>
                        <TextBox x:Name="AmountTextBox" Margin="0,0,0,10"/>

                        <TextBlock Text="Wybierz konto:"/>
                        <ComboBox x:Name="AccountComboBox"
                                  Margin="0,0,0,10"
                                  DisplayMemberPath="DisplayName"/>


                        <TextBlock Text="Data transakcji:"/>
                        <DatePicker x:Name="TransactionDatePicker" Margin="0,0,0,10"/>

                        <TextBlock Text="Opis:"/>
                        <TextBox x:Name="DescriptionTextBox" Margin="0,0,0,10"/>

                        <TextBlock Text="Kategoria:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                            <ComboBox x:Name="CategoryComboBox" 
              DisplayMemberPath="Name" 
              Width="200" />

                            <Button Content="+" Width="30" Margin="10,0,0,0" Click="AddCategoryButton_Click" ToolTip="Dodaj własną kategorię" Cursor="Hand"/>

                        </StackPanel>

                        <TextBlock Text="Typ transakcji:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="ExpenseRadio"
                                         Content="Wydatek"
                                         IsChecked="True"
                                         Margin="0,0,20,0"/>
                            <RadioButton x:Name="IncomeRadio"
                                         Content="Przychód"/>
                        </StackPanel>

                        <Button x:Name="SaveButton"
                                Content="Dodaj transakcję"
                                Click="SaveButton_Click"
                                Padding="10"
                                Background="#0078D7"
                                Foreground="White"
                                FontWeight="Bold"/>

                        <TextBlock Text="Transfer miedzy kontami"
                                   FontWeight="Bold"
                                   Margin="0,16,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="TransferFromComboBox"
                                      Width="200"
                                      Margin="0,0,10,0"
                                      DisplayMemberPath="DisplayName"/>
                            <ComboBox x:Name="TransferToComboBox"
                                      Width="200"
                                      Margin="0,0,10,0"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TransferAmountTextBox"
                                     Width="100"
                                     Margin="0,0,10,0"
                                     ToolTip="Kwota transferu"/>
                            <TextBox x:Name="TransferDescriptionTextBox"
                                     Width="240"
                                     Margin="0,0,10,0"
                                     ToolTip="Opis transferu"/>
                            <Button Content="Wykonaj transfer"
                                    Width="120"
                                    Click="TransferButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Konta">
                <Border Background="White" Margin="10" Padding="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Zarzadzanie kontami"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Dodaj nowe konto" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox x:Name="NewAccountNameTextBox"
                                     Width="220"
                                     Margin="0,0,10,0"
                                     ToolTip="Nazwa nowego konta"/>
                            <ComboBox x:Name="NewAccountTypeComboBox"
                                      Width="120"
                                      Margin="0,0,10,0">
                                <ComboBoxItem Content="Osobiste" IsSelected="True"/>
                                <ComboBoxItem Content="Wspolne"/>
                            </ComboBox>
                            <Button Content="Dodaj konto"
                                    Width="110"
                                    Click="AddAccountButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 🟢 TRANSAKCJE -->
            <TabItem Header="Transakcje">
                <views:TransactionsView/>
            </TabItem>

            <!-- 🟣 PODSUMOWANIE -->
            <TabItem Header="Podsumowanie">
                <views:SummaryView/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>