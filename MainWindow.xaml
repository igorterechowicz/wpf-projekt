<Window x:Class="wpf_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:wpf_projekt.Views"
        Title="Zarządzanie Finansami" Height="600" Width="700"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <TabControl>

            <!-- 🔵 DODAJ -->
            <TabItem Header="Dodaj">
                <Border Background="White" Margin="10" Padding="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="Dodaj nową transakcję"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Kwota (zł):"/>
                        <TextBox x:Name="AmountTextBox" Margin="0,0,0,10"/>

                        <TextBlock Text="Wybierz konto:"/>
                        <ComboBox x:Name="AccountComboBox" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Konto #" />
                                        <TextBlock Text="{Binding Id}" />
                                        <TextBlock Text=" (Saldo: " Margin="5,0,0,0"/>
                                        <TextBlock Text="{Binding Balance}" FontWeight="Bold"/>
                                        <TextBlock Text=" zł)"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Data transakcji:"/>
                        <DatePicker x:Name="TransactionDatePicker" Margin="0,0,0,10"/>

                        <TextBlock Text="Opis:"/>
                        <TextBox x:Name="DescriptionTextBox" Margin="0,0,0,10"/>

                        <TextBlock Text="Kategoria:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                            <ComboBox x:Name="CategoryComboBox" 
              DisplayMemberPath="Name" 
              Width="200" />

                            <Button Content="+" Width="30" Margin="10,0,0,0" Click="AddCategoryButton_Click" ToolTip="Dodaj własną kategorię" Cursor="Hand"/>

                        </StackPanel>

                        <TextBlock Text="Typ transakcji:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="ExpenseRadio"
                                         Content="Wydatek"
                                         IsChecked="True"
                                         Margin="0,0,20,0"/>
                            <RadioButton x:Name="IncomeRadio"
                                         Content="Przychód"/>
                        </StackPanel>

                        <Button x:Name="SaveButton"
                                Content="Dodaj transakcję"
                                Click="SaveButton_Click"
                                Padding="10"
                                Background="#0078D7"
                                Foreground="White"
                                FontWeight="Bold"/>

                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 🟢 TRANSAKCJE -->
            <TabItem Header="Transakcje">
                <views:TransactionsView/>
            </TabItem>

            <!-- 🟣 PODSUMOWANIE -->
            <TabItem Header="Podsumowanie">
                <views:SummaryView/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>